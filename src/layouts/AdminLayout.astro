---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = '内容管理 · Sakuapi', description = '内容管理后台' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body class="min-h-screen bg-neutral-50">
  <header class="border-b border-neutral-200 bg-white">
    <div class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between">
      <a href="/admin" class="flex items-center gap-2 group">
        <span class="text-lg font-bold tracking-tight text-orange-700">Sakuapi</span>
        <span class="text-sm text-neutral-500">/ 内容管理</span>
      </a>
      <div class="flex items-center gap-4 text-sm">
        <a href="/" class="text-neutral-600 hover:text-orange-700 transition">查看站点 →</a>
        <span class="text-neutral-300">|</span>
        <span id="admin-user-email" class="text-neutral-500">…</span>
        <a href="/cdn-cgi/access/logout" class="text-neutral-500 hover:text-red-600 transition">登出</a>
      </div>
    </div>
  </header>

  <main class="pb-20">
    <slot />
  </main>

  <script is:inline>
    // 拉一次 /api/me 显示当前邮箱
    (async () => {
      const el = document.getElementById('admin-user-email');
      if (!el) return;
      try {
        const r = await fetch('/api/me');
        if (!r.ok) {
          el.textContent = '未登录';
          el.classList.add('text-red-600');
          return;
        }
        const data = await r.json();
        el.textContent = data.email + (data.dev ? ' (本地)' : '');
      } catch (err) {
        el.textContent = 'API 错误';
        el.classList.add('text-red-600');
      }
    })();
  </script>
</body>
</html>
