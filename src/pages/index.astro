---
import Layout from '../layouts/Layout.astro';
import { GROUPS, colorClasses } from '../lib/groups';
import { getAllArticles } from '../lib/articles';

const articles = await getAllArticles();
const counts = new Map<string, number>();
for (const a of articles) counts.set(a.group, (counts.get(a.group) || 0) + 1);
---

<Layout title="Sakuapi · 内部内容站">
  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="mb-12">
      <h1 class="text-3xl font-bold tracking-tight mb-3">内部内容站</h1>
      <p class="text-neutral-600 leading-relaxed">
        按小组分类的内部资料库 · 共 <strong>{articles.length}</strong> 篇
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      {GROUPS.map((g) => {
        const c = colorClasses(g.color);
        const count = counts.get(g.key) || 0;
        return (
          <a
            href={`/${g.key}/`}
            class={`block group p-6 bg-white border border-neutral-200 rounded-lg ${c.border} hover:shadow-sm transition`}
          >
            <div class="flex items-baseline justify-between mb-2">
              <h2 class={`text-xl font-semibold text-neutral-900 ${c.text} transition`}>
                {g.name}
              </h2>
              <span class="text-sm text-neutral-500">{count} 篇</span>
            </div>
            <p class="text-sm text-neutral-600 leading-relaxed">{g.description}</p>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
