---
import Layout from "../layouts/Layout.astro";
import WorkflowFields from '../components/WorkflowFields.astro';
import { GROUPS } from '../lib/groups';

const groupsJson = JSON.stringify(GROUPS);
---

<Layout title="新建文章 · Sakuapi">
  <link rel="stylesheet" href="https://unpkg.com/easymde@2.18.0/dist/easymde.min.css" />

  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <a href="/" class="text-sm text-neutral-500 hover:text-orange-700 transition">← 返回列表</a>
        <h1 class="text-2xl font-bold tracking-tight mt-1">新建文章</h1>
      </div>
    </div>

    <div id="form-error" class="hidden mb-4 p-4 bg-red-50 border border-red-200 rounded-md text-red-700 text-sm"></div>
    <div id="form-success" class="hidden mb-4 p-4 bg-green-50 border border-green-200 rounded-md text-green-700 text-sm"></div>

    <form id="article-form" class="bg-white border border-neutral-200 rounded-lg p-6 space-y-5">
      <div class="grid sm:grid-cols-2 gap-4">
        <label class="block">
          <span class="block text-sm font-medium text-neutral-700 mb-1">分组</span>
          <select id="f-group" class="w-full border border-neutral-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" required>
            <!-- 由 JS 填充 -->
          </select>
        </label>

        <label class="block">
          <span class="block text-sm font-medium text-neutral-700 mb-1">日期（批次目录名）</span>
          <input id="f-date" type="date" class="w-full border border-neutral-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" required />
        </label>
      </div>

      <label class="block">
        <span class="block text-sm font-medium text-neutral-700 mb-1">文章标题（显示用）</span>
        <input id="f-title" type="text" class="w-full border border-neutral-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" placeholder="0.2 分的差距，这家餐厅一个月少了 2500 万日元" />
      </label>

      <label class="block">
        <span class="block text-sm font-medium text-neutral-700 mb-1">文件名（不含 .md，建议 <code class="text-xs bg-neutral-100 px-1 rounded">01-标题</code>）</span>
        <input id="f-filename" type="text" class="w-full border border-neutral-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" placeholder="01-我的第一篇" required />
        <span class="block text-xs text-neutral-500 mt-1">完整路径预览: <span id="path-preview" class="font-mono">…</span></span>
      </label>

      <WorkflowFields />

      <div>
        <div class="flex items-center justify-between mb-1">
          <span class="block text-sm font-medium text-neutral-700">正文（Markdown）</span>
          <span class="text-xs text-neutral-500">支持 # 标题、**粗体**、表格、图片等</span>
        </div>
        <textarea id="f-content" required></textarea>
      </div>

      <div class="flex items-center justify-end gap-3 pt-2 border-t border-neutral-100">
        <a href="/" class="px-4 py-2 text-sm text-neutral-600 hover:text-neutral-800 transition">取消</a>
        <button id="submit-btn" type="submit" class="px-5 py-2 bg-orange-600 hover:bg-orange-700 text-white rounded-md font-medium shadow-sm transition disabled:opacity-50 disabled:cursor-not-allowed">
          提交并 commit
        </button>
      </div>
    </form>
  </div>

  <input id="image-upload-input" type="file" accept="image/*" class="hidden" />

  <script src="https://unpkg.com/marked@13.0.3/marked.min.js" is:inline></script>
  <script src="https://unpkg.com/easymde@2.18.0/dist/easymde.min.js" is:inline></script>
  <script src="/scripts/frontmatter.js" is:inline></script>

  <script is:inline define:vars={{ groupsJson }}>
    const GROUPS = JSON.parse(groupsJson);

    // ---------- group select ----------
    const groupSel = document.getElementById('f-group');
    for (const g of GROUPS) {
      const opt = document.createElement('option');
      opt.value = g.key;
      opt.textContent = `${g.name} (${g.key})`;
      groupSel.appendChild(opt);
    }
    if (GROUPS.some((g) => g.key === 'restaurant')) groupSel.value = 'restaurant';
    // 从 ?group= query 预选
    const qsGroup = new URL(window.location.href).searchParams.get('group');
    if (qsGroup && GROUPS.some((g) => g.key === qsGroup)) groupSel.value = qsGroup;

    // ---------- date default ----------
    const dateInp = document.getElementById('f-date');
    const today = new Date();
    const yyyy = today.getFullYear();
    const mm = String(today.getMonth() + 1).padStart(2, '0');
    const dd = String(today.getDate()).padStart(2, '0');
    dateInp.value = `${yyyy}-${mm}-${dd}`;

    // ---------- preview ----------
    const fnInp = document.getElementById('f-filename');
    const titleInp = document.getElementById('f-title');
    const preview = document.getElementById('path-preview');
    function refreshPreview() {
      const g = groupSel.value;
      const d = dateInp.value || 'YYYY-MM-DD';
      const f = (fnInp.value || '未命名').replace(/\.md$/, '');
      preview.textContent = `src/content/articles/${g}/${d}/${f}.md`;
    }
    [groupSel, dateInp, fnInp].forEach((el) => el.addEventListener('input', refreshPreview));
    refreshPreview();

    // ---------- clone from edit page ----------
    const url = new URL(window.location.href);
    const isClone = url.searchParams.get('clone') === '1';
    let initialContent = '';
    let initialFM = {};
    if (isClone) {
      try {
        initialContent = sessionStorage.getItem('sakuapi-clone-content') || '';
        const fmJson = sessionStorage.getItem('sakuapi-clone-frontmatter');
        if (fmJson) initialFM = JSON.parse(fmJson);
        const cg = sessionStorage.getItem('sakuapi-clone-group');
        if (cg && GROUPS.some((g) => g.key === cg)) groupSel.value = cg;
        sessionStorage.removeItem('sakuapi-clone-content');
        sessionStorage.removeItem('sakuapi-clone-frontmatter');
        sessionStorage.removeItem('sakuapi-clone-group');
      } catch {}
    }

    // ---------- editor ----------
    const easymde = new EasyMDE({
      element: document.getElementById('f-content'),
      spellChecker: false,
      autosave: { enabled: true, uniqueId: `sakuapi-draft-new-${groupSel.value}`, delay: 1500 },
      status: ['lines', 'words'],
      minHeight: '400px',
      previewRender: (text) => (window.marked ? window.marked.parse(text) : text),
      toolbar: [
        'bold', 'italic', 'heading', '|',
        'quote', 'unordered-list', 'ordered-list', '|',
        'link', {
          name: 'image-upload',
          action: () => triggerImageUpload(),
          className: 'fa fa-upload',
          title: '上传图片',
        }, 'table', '|',
        'preview', 'side-by-side', 'fullscreen', '|',
        'guide',
      ],
    });

    groupSel.addEventListener('change', () => {
      easymde.options.autosave.uniqueId = `sakuapi-draft-new-${groupSel.value}`;
    });

    if (initialContent) easymde.value(initialContent);
    if (Object.keys(initialFM).length) {
      window.SakuapiWF.write(initialFM);
      if (initialFM.title) titleInp.value = initialFM.title;
    }

    // ---------- image upload ----------
    const fileInp = document.getElementById('image-upload-input');
    function triggerImageUpload() {
      fileInp.value = '';
      fileInp.click();
    }
    fileInp.addEventListener('change', async () => {
      const f = fileInp.files && fileInp.files[0];
      if (!f) return;
      const placeholder = `![上传中…${f.name}]()`;
      const cm = easymde.codemirror;
      const pos = cm.getCursor();
      cm.replaceRange(placeholder, pos);

      try {
        const fd = new FormData();
        fd.append('file', f);
        fd.append('group', groupSel.value);
        const r = await fetch('/api/upload', { method: 'POST', body: fd });
        const data = await r.json();
        if (!r.ok) throw new Error(data.error || '上传失败');
        const md = `![${f.name}](${data.url})`;
        const cur = easymde.value();
        easymde.value(cur.replace(placeholder, md));
      } catch (err) {
        const cur = easymde.value();
        easymde.value(cur.replace(placeholder, ''));
        alert('图片上传失败: ' + err.message);
      }
    });

    // ---------- submit ----------
    const form = document.getElementById('article-form');
    const errBox = document.getElementById('form-error');
    const okBox = document.getElementById('form-success');
    const submitBtn = document.getElementById('submit-btn');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errBox.classList.add('hidden');
      okBox.classList.add('hidden');

      const group = groupSel.value;
      const date = dateInp.value;
      let filename = fnInp.value.trim().replace(/\.md$/, '').replace(/^\/+|\/+$/g, '');
      if (!group || !date || !filename) {
        errBox.textContent = '请填写分组、日期、文件名';
        errBox.classList.remove('hidden');
        return;
      }
      if (filename.includes('/') || filename.includes('..')) {
        errBox.textContent = '文件名不能包含 / 或 ..';
        errBox.classList.remove('hidden');
        return;
      }
      const body = easymde.value();
      if (!body.trim()) {
        errBox.textContent = '正文不能为空';
        errBox.classList.remove('hidden');
        return;
      }

      // 组装 frontmatter
      const fm = window.SakuapiWF.read();
      if (titleInp.value.trim()) fm.title = titleInp.value.trim();
      fm.date = date;

      const content = window.SakuapiFM.serializeFrontmatter(fm, body);
      const path = `src/content/articles/${group}/${date}/${filename}.md`;

      submitBtn.disabled = true;
      submitBtn.textContent = '提交中…';
      try {
        const r = await fetch('/api/article', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ path, content, message: `add: ${group}/${date}/${filename}.md via admin` }),
        });
        const data = await r.json();
        if (!r.ok) throw new Error(data.error || '提交失败');
        try { easymde.clearAutosavedValue(); } catch {}
        okBox.innerHTML = `已提交！commit <a class="underline" target="_blank" href="${data.commitUrl}">${(data.commitSha || '').slice(0, 7)}</a> · 跳转中…`;
        okBox.classList.remove('hidden');
        setTimeout(() => { window.location.href = `/${group}/`; }, 1200);
      } catch (err) {
        errBox.textContent = '提交失败: ' + err.message;
        errBox.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = '提交并 commit';
      }
    });
  </script>
</Layout>
