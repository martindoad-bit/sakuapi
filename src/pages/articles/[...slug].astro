---
import Layout from '../../layouts/Layout.astro';
import { getAllArticles } from '../../lib/articles';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getAllArticles();
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article.entry);
---

<Layout title={`${article.title} · Sakuapi`} description={article.excerpt}>
  <article class="max-w-3xl mx-auto px-6 py-12">
    <div class="mb-8">
      <a href="/" class="text-sm text-neutral-500 hover:text-orange-700 transition">← 返回列表</a>
    </div>

    <div class="text-xs text-neutral-500 mb-2 uppercase tracking-wider">
      {article.folder}
    </div>

    <div class="prose">
      <Content />
    </div>

    <div class="mt-16 pt-8 border-t border-neutral-200">
      <a href="/" class="text-sm text-neutral-500 hover:text-orange-700 transition">← 返回列表</a>
    </div>
  </article>
</Layout>
