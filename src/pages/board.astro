---
import Layout from "../layouts/Layout.astro";
import { GROUPS } from '../lib/groups';
import { STATUSES } from '../lib/workflow';

const groupsJson = JSON.stringify(GROUPS);
const statusesJson = JSON.stringify(STATUSES);
---

<Layout title="看板 · Sakuapi">
  <div class="max-w-full mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-6 gap-3 flex-wrap">
      <div>
        <h1 class="text-2xl font-bold tracking-tight mb-1">看板</h1>
        <p class="text-sm text-neutral-600">按状态分列，**拖拽卡片**改变状态（自动 commit 到 GitHub）</p>
      </div>
      <div class="flex items-center gap-2">
        <a href="/" class="px-3 py-2 text-sm border border-neutral-300 rounded-md hover:border-orange-400 hover:text-orange-700 transition">📄 列表</a>
        <a href="/calendar" class="px-3 py-2 text-sm border border-neutral-300 rounded-md hover:border-orange-400 hover:text-orange-700 transition">📅 日历</a>
        <a href="/new" class="px-4 py-2 bg-orange-600 hover:bg-orange-700 text-white rounded-md font-medium shadow-sm transition">+ 新建</a>
      </div>
    </div>

    <!-- 组筛选 -->
    <div class="mb-4 flex flex-wrap items-center gap-2">
      <span class="text-xs text-neutral-500 mr-1">分组：</span>
      <button data-filter-group="" class="group-filter text-xs px-2.5 py-1 rounded-full border border-neutral-300 hover:border-orange-400 transition data-[active=true]:bg-orange-600 data-[active=true]:text-white data-[active=true]:border-orange-600" data-active="true">全部</button>
      {GROUPS.map((g) => (
        <button data-filter-group={g.key} class="group-filter text-xs px-2.5 py-1 rounded-full border border-neutral-300 hover:border-orange-400 transition data-[active=true]:bg-orange-600 data-[active=true]:text-white data-[active=true]:border-orange-600">{g.name}</button>
      ))}
    </div>

    <div id="loading" class="text-center py-12 text-neutral-500">
      <div class="inline-block w-6 h-6 border-2 border-neutral-300 border-t-orange-600 rounded-full animate-spin mb-3"></div>
      <div>加载中…</div>
    </div>

    <div id="board" class="hidden grid gap-4" style="grid-template-columns: repeat(7, minmax(220px, 1fr)); overflow-x: auto;">
      <!-- 由 JS 渲染 7 列 -->
    </div>
  </div>

  <script src="/scripts/frontmatter.js" is:inline></script>

  <script is:inline define:vars={{ groupsJson, statusesJson }}>
    const GROUPS = JSON.parse(groupsJson);
    const STATUSES = JSON.parse(statusesJson);
    const STATUS_BY_KEY = Object.fromEntries(STATUSES.map((s) => [s.key, s]));
    const GROUP_BY_KEY = Object.fromEntries(GROUPS.map((g) => [g.key, g]));
    let allItems = [];
    let activeGroupFilter = '';
    const boardEl = document.getElementById('board');

    function buildCard(item) {
      const fm = item.frontmatter || {};
      const card = document.createElement('div');
      card.className = 'bg-white border border-neutral-200 rounded-md p-3 shadow-sm cursor-grab active:cursor-grabbing hover:border-orange-300 transition';
      card.draggable = true;
      card.dataset.path = item.path;
      card.dataset.sha = item.sha || '';

      const g = GROUP_BY_KEY[item.group];
      card.innerHTML = `
        <div class="text-xs text-neutral-500 mb-1">${g?.name || item.group} · ${item.batch || ''}</div>
        <div class="text-sm font-medium text-neutral-800 leading-snug mb-2 line-clamp-2">${escapeHtml(item.title)}</div>
        ${fm.assignee ? `<div class="text-xs text-neutral-600 mb-1">@${escapeHtml(fm.assignee)}</div>` : ''}
        ${fm.shoot_date ? `<div class="text-xs text-purple-700">🎬 ${fm.shoot_date}</div>` : ''}
        ${fm.publish_date ? `<div class="text-xs text-cyan-700">🚀 ${fm.publish_date}</div>` : ''}
        <a href="/edit?path=${encodeURIComponent(item.path)}" class="text-xs text-orange-700 hover:underline mt-2 inline-block">编辑 →</a>
      `;

      card.addEventListener('dragstart', (e) => {
        e.dataTransfer.setData('text/plain', item.path);
        e.dataTransfer.effectAllowed = 'move';
        card.classList.add('opacity-50');
      });
      card.addEventListener('dragend', () => card.classList.remove('opacity-50'));
      return card;
    }

    function escapeHtml(s) {
      return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    function renderBoard() {
      boardEl.innerHTML = '';
      const filtered = activeGroupFilter
        ? allItems.filter((i) => i.group === activeGroupFilter)
        : allItems;

      // 7 列 = 7 个状态
      const cols = STATUSES.map((s) => ({ status: s, items: [] }));
      const noStatus = [];
      for (const item of filtered) {
        const fm = item.frontmatter || {};
        const idx = STATUSES.findIndex((s) => s.key === fm.status);
        if (idx >= 0) cols[idx].items.push(item);
        else noStatus.push(item);
      }
      // 把没状态的放到第一列「写稿中」
      cols[0].items.push(...noStatus);

      for (const col of cols) {
        const colEl = document.createElement('div');
        colEl.className = `${col.status.bg} rounded-lg p-3`;
        colEl.dataset.status = col.status.key;
        colEl.innerHTML = `
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-sm font-semibold ${col.status.text}">${col.status.label}</h3>
            <span class="text-xs ${col.status.text} opacity-70">${col.items.length}</span>
          </div>
          <div class="space-y-2 min-h-[100px]" data-drop></div>
        `;
        const dropZone = colEl.querySelector('[data-drop]');
        for (const item of col.items) dropZone.appendChild(buildCard(item));

        colEl.addEventListener('dragover', (e) => {
          e.preventDefault();
          e.dataTransfer.dropEffect = 'move';
          colEl.classList.add('ring-2', col.status.ring);
        });
        colEl.addEventListener('dragleave', () => colEl.classList.remove('ring-2', col.status.ring));
        colEl.addEventListener('drop', async (e) => {
          e.preventDefault();
          colEl.classList.remove('ring-2', col.status.ring);
          const path = e.dataTransfer.getData('text/plain');
          const item = allItems.find((i) => i.path === path);
          if (!item) return;
          if ((item.frontmatter || {}).status === col.status.key) return;

          // 乐观 UI：先移过去
          await updateStatus(item, col.status.key);
        });

        boardEl.appendChild(colEl);
      }
    }

    async function updateStatus(item, newStatus) {
      // 拉文件 → 改 frontmatter → 提交
      try {
        const r1 = await fetch(`/api/article?path=${encodeURIComponent(item.path)}`);
        const d1 = await r1.json();
        if (!r1.ok) throw new Error(d1.error || '加载失败');
        const { frontmatter, body } = window.SakuapiFM.parseFrontmatter(d1.content);
        const newFM = { ...frontmatter, status: newStatus };
        const newContent = window.SakuapiFM.serializeFrontmatter(newFM, body);

        const r2 = await fetch('/api/article', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ path: item.path, content: newContent, sha: d1.sha, message: `status: ${newStatus} ← board` }),
        });
        const d2 = await r2.json();
        if (!r2.ok) throw new Error(d2.error || '保存失败');
        // 更新本地 cache
        item.frontmatter = newFM;
        renderBoard();
      } catch (err) {
        alert('改状态失败: ' + err.message);
      }
    }

    document.querySelectorAll('.group-filter').forEach((btn) => {
      btn.addEventListener('click', () => {
        activeGroupFilter = btn.dataset.filterGroup;
        document.querySelectorAll('.group-filter').forEach((b) => b.dataset.active = (b === btn).toString());
        renderBoard();
      });
    });

    (async function load() {
      try {
        const r = await fetch('/api/list?frontmatter=1');
        const data = await r.json();
        if (!r.ok) throw new Error(data.error || `HTTP ${r.status}`);
        allItems = data.items || [];
        document.getElementById('loading').classList.add('hidden');
        boardEl.classList.remove('hidden');
        renderBoard();
      } catch (err) {
        document.getElementById('loading').innerHTML = `<div class="text-red-600">加载失败: ${err.message}</div>`;
      }
    })();
  </script>
</Layout>
