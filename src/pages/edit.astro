---
import Layout from "../layouts/Layout.astro";
import WorkflowFields from '../components/WorkflowFields.astro';
---

<Layout title="编辑文章 · Sakuapi">
  <link rel="stylesheet" href="https://unpkg.com/easymde@2.18.0/dist/easymde.min.css" />

  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <a href="/" class="text-sm text-neutral-500 hover:text-orange-700 transition">← 返回列表</a>
        <h1 class="text-2xl font-bold tracking-tight mt-1">编辑文章</h1>
        <p class="text-xs text-neutral-500 mt-1 font-mono" id="path-display">…</p>
      </div>
    </div>

    <div id="form-error" class="hidden mb-4 p-4 bg-red-50 border border-red-200 rounded-md text-red-700 text-sm"></div>
    <div id="form-success" class="hidden mb-4 p-4 bg-green-50 border border-green-200 rounded-md text-green-700 text-sm"></div>

    <div id="loading" class="bg-white border border-neutral-200 rounded-lg p-12 text-center text-neutral-500">
      <div class="inline-block w-6 h-6 border-2 border-neutral-300 border-t-orange-600 rounded-full animate-spin mb-3"></div>
      <div>加载中…</div>
    </div>

    <form id="article-form" class="hidden bg-white border border-neutral-200 rounded-lg p-6 space-y-5">
      <label class="block">
        <span class="block text-sm font-medium text-neutral-700 mb-1">文章标题（显示用）</span>
        <input id="f-title" type="text" class="w-full border border-neutral-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" />
      </label>

      <WorkflowFields />

      <div>
        <div class="flex items-center justify-between mb-1">
          <span class="block text-sm font-medium text-neutral-700">正文（Markdown）</span>
          <span class="text-xs text-neutral-500">改完点保存即可，commit 自动用你的邮箱</span>
        </div>
        <textarea id="f-content" required></textarea>
      </div>

      <div class="flex items-center justify-between gap-3 pt-2 border-t border-neutral-100">
        <button id="save-as-new-btn" type="button" class="text-sm text-neutral-600 hover:text-orange-700 transition">
          另存为新文章 →
        </button>
        <div class="flex items-center gap-3">
          <a href="/" class="px-4 py-2 text-sm text-neutral-600 hover:text-neutral-800 transition">取消</a>
          <button id="save-btn" type="submit" class="px-5 py-2 bg-orange-600 hover:bg-orange-700 text-white rounded-md font-medium shadow-sm transition disabled:opacity-50 disabled:cursor-not-allowed">
            保存并 commit
          </button>
        </div>
      </div>
    </form>
  </div>

  <input id="image-upload-input" type="file" accept="image/*" class="hidden" />

  <script src="https://unpkg.com/marked@13.0.3/marked.min.js" is:inline></script>
  <script src="https://unpkg.com/easymde@2.18.0/dist/easymde.min.js" is:inline></script>
  <script src="/scripts/frontmatter.js" is:inline></script>

  <script is:inline>
    const params = new URLSearchParams(window.location.search);
    const path = params.get('path') || '';
    const errBox = document.getElementById('form-error');
    const okBox = document.getElementById('form-success');
    const loading = document.getElementById('loading');
    const form = document.getElementById('article-form');
    const pathDisplay = document.getElementById('path-display');
    const titleInp = document.getElementById('f-title');
    const saveBtn = document.getElementById('save-btn');
    const saveAsNewBtn = document.getElementById('save-as-new-btn');

    pathDisplay.textContent = path || '(无 path 参数)';

    if (!path || !path.startsWith('src/content/articles/') || !path.endsWith('.md')) {
      loading.innerHTML = '<div class="text-red-600">无效路径</div>';
      throw new Error('invalid path');
    }

    const pathParts = path.replace(/^src\/content\/articles\//, '').split('/');
    const groupKey = pathParts[0] || 'shared';

    let easymde = null;
    let currentSha = '';
    let currentFM = {};

    (async function bootstrap() {
      try {
        const r = await fetch(`/api/article?path=${encodeURIComponent(path)}`);
        const data = await r.json();
        if (!r.ok) throw new Error(data.error || `HTTP ${r.status}`);
        currentSha = data.sha;

        // 拆 frontmatter / body
        const { frontmatter, body } = window.SakuapiFM.parseFrontmatter(data.content);
        currentFM = frontmatter || {};

        loading.classList.add('hidden');
        form.classList.remove('hidden');

        // 填表单
        if (currentFM.title) titleInp.value = currentFM.title;
        window.SakuapiWF.write(currentFM);

        document.getElementById('f-content').value = body;
        easymde = new EasyMDE({
          element: document.getElementById('f-content'),
          spellChecker: false,
          autosave: { enabled: true, uniqueId: `sakuapi-edit-${path}`, delay: 1500 },
          status: ['lines', 'words'],
          minHeight: '400px',
          previewRender: (text) => (window.marked ? window.marked.parse(text) : text),
          toolbar: [
            'bold', 'italic', 'heading', '|',
            'quote', 'unordered-list', 'ordered-list', '|',
            'link', {
              name: 'image-upload',
              action: () => triggerImageUpload(),
              className: 'fa fa-upload',
              title: '上传图片',
            }, 'table', '|',
            'preview', 'side-by-side', 'fullscreen', '|',
            'guide',
          ],
        });
        easymde.value(body);
      } catch (err) {
        loading.innerHTML = `<div class="text-red-600">加载失败: ${err.message}</div>`;
      }
    })();

    // ---------- image upload ----------
    const fileInp = document.getElementById('image-upload-input');
    function triggerImageUpload() {
      fileInp.value = '';
      fileInp.click();
    }
    fileInp.addEventListener('change', async () => {
      const f = fileInp.files && fileInp.files[0];
      if (!f || !easymde) return;
      const placeholder = `![上传中…${f.name}]()`;
      const cm = easymde.codemirror;
      const pos = cm.getCursor();
      cm.replaceRange(placeholder, pos);
      try {
        const fd = new FormData();
        fd.append('file', f);
        fd.append('group', groupKey);
        const r = await fetch('/api/upload', { method: 'POST', body: fd });
        const data = await r.json();
        if (!r.ok) throw new Error(data.error || '上传失败');
        const md = `![${f.name}](${data.url})`;
        const cur = easymde.value();
        easymde.value(cur.replace(placeholder, md));
      } catch (err) {
        const cur = easymde.value();
        easymde.value(cur.replace(placeholder, ''));
        alert('图片上传失败: ' + err.message);
      }
    });

    // ---------- save ----------
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errBox.classList.add('hidden');
      okBox.classList.add('hidden');
      if (!easymde) return;

      const body = easymde.value();
      if (!body.trim()) {
        errBox.textContent = '正文不能为空';
        errBox.classList.remove('hidden');
        return;
      }

      // 重组 frontmatter
      const fm = window.SakuapiWF.read();
      if (titleInp.value.trim()) fm.title = titleInp.value.trim();
      // 保留原 frontmatter 里我们不管的字段
      for (const k of Object.keys(currentFM)) {
        if (!(k in fm) && currentFM[k] !== undefined) fm[k] = currentFM[k];
      }
      const content = window.SakuapiFM.serializeFrontmatter(fm, body);

      saveBtn.disabled = true;
      saveBtn.textContent = '保存中…';
      try {
        const r = await fetch('/api/article', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ path, content, sha: currentSha, message: `update: ${path.replace(/^src\/content\/articles\//, '')} via admin` }),
        });
        const data = await r.json();
        if (!r.ok) throw new Error(data.error || '保存失败');
        currentSha = data.sha;
        try { easymde.clearAutosavedValue(); } catch {}
        okBox.innerHTML = `已保存！commit <a class="underline" target="_blank" href="${data.commitUrl}">${(data.commitSha || '').slice(0, 7)}</a>`;
        okBox.classList.remove('hidden');
      } catch (err) {
        errBox.textContent = '保存失败: ' + err.message;
        errBox.classList.remove('hidden');
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = '保存并 commit';
      }
    });

    // ---------- 另存为新 ----------
    saveAsNewBtn.addEventListener('click', () => {
      if (!easymde) return;
      const body = easymde.value();
      const fm = window.SakuapiWF.read();
      if (titleInp.value.trim()) fm.title = titleInp.value.trim();
      try {
        sessionStorage.setItem('sakuapi-clone-content', body);
        sessionStorage.setItem('sakuapi-clone-frontmatter', JSON.stringify(fm));
        sessionStorage.setItem('sakuapi-clone-group', groupKey);
        window.location.href = '/new?clone=1';
      } catch {
        window.location.href = '/new';
      }
    });
  </script>
</Layout>
