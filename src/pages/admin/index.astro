---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { GROUPS } from '../../lib/groups';

// 序列化 groups 给 client 端 script 用
const groupsJson = JSON.stringify(GROUPS);
---

<AdminLayout title="文章管理 · Sakuapi">
  <div class="max-w-6xl mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold tracking-tight mb-1">文章管理</h1>
        <p class="text-sm text-neutral-600">所有改动会直接 commit 到 GitHub，几分钟后自动部署上线</p>
      </div>
      <a
        href="/admin/new"
        class="inline-flex items-center gap-2 px-4 py-2 bg-orange-600 hover:bg-orange-700 text-white rounded-md font-medium shadow-sm transition"
      >
        <span class="text-lg leading-none">+</span> 新建文章
      </a>
    </div>

    <div id="admin-error" class="hidden mb-6 p-4 bg-red-50 border border-red-200 rounded-md text-red-700 text-sm"></div>

    <div id="admin-groups" class="grid gap-6 md:grid-cols-2"></div>

    <template id="tpl-card">
      <section class="bg-white border border-neutral-200 rounded-lg p-5">
        <header class="flex items-baseline justify-between mb-4">
          <h2 class="text-lg font-semibold" data-name></h2>
          <span class="text-xs text-neutral-500" data-count></span>
        </header>
        <p class="text-xs text-neutral-500 mb-3" data-desc></p>
        <ul class="divide-y divide-neutral-100" data-list></ul>
        <div class="text-sm text-neutral-400 italic hidden" data-empty>暂无文章</div>
      </section>
    </template>

    <template id="tpl-row">
      <li class="py-2 flex items-center justify-between gap-3">
        <div class="min-w-0 flex-1">
          <div class="text-sm font-medium text-neutral-800 truncate" data-title></div>
          <div class="text-xs text-neutral-500 mt-0.5 truncate" data-meta></div>
        </div>
        <div class="flex items-center gap-2 shrink-0 text-xs">
          <a class="px-2 py-1 text-orange-700 hover:bg-orange-50 rounded transition" data-edit>编辑</a>
          <button class="px-2 py-1 text-red-600 hover:bg-red-50 rounded transition" data-del type="button">删除</button>
        </div>
      </li>
    </template>

    <template id="tpl-skeleton">
      <section class="bg-white border border-neutral-200 rounded-lg p-5 animate-pulse">
        <div class="h-5 bg-neutral-200 rounded w-1/3 mb-4"></div>
        <div class="space-y-2">
          <div class="h-4 bg-neutral-100 rounded"></div>
          <div class="h-4 bg-neutral-100 rounded"></div>
          <div class="h-4 bg-neutral-100 rounded w-2/3"></div>
        </div>
      </section>
    </template>
  </div>

  <script is:inline define:vars={{ groupsJson }}>
    const GROUPS = JSON.parse(groupsJson);
    const root = document.getElementById('admin-groups');
    const errBox = document.getElementById('admin-error');
    const cardTpl = document.getElementById('tpl-card');
    const rowTpl = document.getElementById('tpl-row');
    const skelTpl = document.getElementById('tpl-skeleton');

    function showError(msg) {
      errBox.textContent = msg;
      errBox.classList.remove('hidden');
    }

    function renderSkeleton() {
      root.innerHTML = '';
      for (let i = 0; i < GROUPS.length; i++) {
        root.appendChild(skelTpl.content.cloneNode(true));
      }
    }

    function buildRow(item) {
      const node = rowTpl.content.cloneNode(true);
      node.querySelector('[data-title]').textContent = item.title || item.filename.replace(/\.md$/, '');
      node.querySelector('[data-meta]').textContent = `${item.batch || '(无批次)'} / ${item.filename}`;
      const editBtn = node.querySelector('[data-edit]');
      editBtn.href = `/admin/edit?path=${encodeURIComponent(item.path)}`;
      const delBtn = node.querySelector('[data-del]');
      delBtn.addEventListener('click', () => onDelete(item, delBtn));
      return node;
    }

    async function onDelete(item, btn) {
      if (!confirm(`确认删除？\n\n${item.title || item.filename}\n\n这会立即在 GitHub 上提交一个删除 commit，无法在网页里撤回（但 git 历史保留）。`)) {
        return;
      }
      btn.disabled = true;
      btn.textContent = '删除中…';
      try {
        const r = await fetch(`/api/article?path=${encodeURIComponent(item.path)}`, { method: 'DELETE' });
        const data = await r.json();
        if (!r.ok) throw new Error(data.error || '删除失败');
        await load();
      } catch (err) {
        alert('删除失败: ' + err.message);
        btn.disabled = false;
        btn.textContent = '删除';
      }
    }

    async function load() {
      renderSkeleton();
      let data;
      try {
        const r = await fetch('/api/list');
        data = await r.json();
        if (!r.ok) throw new Error(data.error || `HTTP ${r.status}`);
      } catch (err) {
        root.innerHTML = '';
        showError('加载文章列表失败：' + err.message);
        return;
      }
      const items = data.items || [];
      const byGroup = new Map();
      for (const g of GROUPS) byGroup.set(g.key, []);
      for (const item of items) {
        if (!byGroup.has(item.group)) byGroup.set(item.group, []);
        byGroup.get(item.group).push(item);
      }

      root.innerHTML = '';
      for (const g of GROUPS) {
        const list = byGroup.get(g.key) || [];
        const card = cardTpl.content.cloneNode(true);
        card.querySelector('[data-name]').textContent = g.name;
        card.querySelector('[data-desc]').textContent = g.description;
        card.querySelector('[data-count]').textContent = `${list.length} 篇`;
        const ul = card.querySelector('[data-list]');
        const empty = card.querySelector('[data-empty]');
        if (list.length === 0) {
          empty.classList.remove('hidden');
        } else {
          for (const item of list) ul.appendChild(buildRow(item));
        }
        root.appendChild(card);
      }
    }

    load();
  </script>
</AdminLayout>
