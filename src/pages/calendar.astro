---
import Layout from "../layouts/Layout.astro";
import { GROUPS } from '../lib/groups';
import { STATUSES } from '../lib/workflow';

const groupsJson = JSON.stringify(GROUPS);
const statusesJson = JSON.stringify(STATUSES);
---

<Layout title="日历 · Sakuapi">
  <div class="max-w-7xl mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-6 gap-3 flex-wrap">
      <div>
        <h1 class="text-2xl font-bold tracking-tight mb-1">日历</h1>
        <p class="text-sm text-neutral-600">🎬 = 拍摄日 · 🚀 = 发布日 · 点击月份切换</p>
      </div>
      <div class="flex items-center gap-2">
        <a href="/" class="px-3 py-2 text-sm border border-neutral-300 rounded-md hover:border-orange-400 hover:text-orange-700 transition">📄 列表</a>
        <a href="/board" class="px-3 py-2 text-sm border border-neutral-300 rounded-md hover:border-orange-400 hover:text-orange-700 transition">📋 看板</a>
        <a href="/new" class="px-4 py-2 bg-orange-600 hover:bg-orange-700 text-white rounded-md font-medium shadow-sm transition">+ 新建</a>
      </div>
    </div>

    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-2">
        <button id="prev-month" class="px-3 py-1.5 border border-neutral-300 rounded hover:border-orange-400 transition">◀</button>
        <span id="current-month" class="text-lg font-semibold w-40 text-center">…</span>
        <button id="next-month" class="px-3 py-1.5 border border-neutral-300 rounded hover:border-orange-400 transition">▶</button>
        <button id="today-btn" class="ml-2 px-3 py-1.5 text-sm border border-neutral-300 rounded hover:border-orange-400 transition">今天</button>
      </div>
      <div class="flex items-center gap-2 text-xs text-neutral-500">
        <span class="inline-block w-3 h-3 rounded bg-purple-300"></span>拍摄日
        <span class="inline-block w-3 h-3 rounded bg-cyan-300 ml-2"></span>发布日
      </div>
    </div>

    <div id="loading" class="text-center py-12 text-neutral-500">
      <div class="inline-block w-6 h-6 border-2 border-neutral-300 border-t-orange-600 rounded-full animate-spin mb-3"></div>
      <div>加载中…</div>
    </div>

    <div id="calendar" class="hidden bg-white border border-neutral-200 rounded-lg overflow-hidden">
      <!-- 由 JS 渲染 -->
    </div>
  </div>

  <script is:inline define:vars={{ groupsJson, statusesJson }}>
    const GROUPS = JSON.parse(groupsJson);
    const STATUSES = JSON.parse(statusesJson);
    const STATUS_BY_KEY = Object.fromEntries(STATUSES.map((s) => [s.key, s]));
    const GROUP_BY_KEY = Object.fromEntries(GROUPS.map((g) => [g.key, g]));
    const calEl = document.getElementById('calendar');
    let allItems = [];
    let viewYear, viewMonth; // month: 0-11

    function escapeHtml(s) {
      return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    function fmtMonth(y, m) {
      return `${y}年${String(m + 1).padStart(2, '0')}月`;
    }

    function isoDate(y, m, d) {
      return `${y}-${String(m + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
    }

    function buildDayEvents(dayIso) {
      const events = [];
      for (const item of allItems) {
        const fm = item.frontmatter || {};
        if (fm.shoot_date === dayIso) events.push({ kind: 'shoot', item });
        if (fm.publish_date === dayIso) events.push({ kind: 'publish', item });
      }
      return events;
    }

    function render() {
      document.getElementById('current-month').textContent = fmtMonth(viewYear, viewMonth);

      const firstDay = new Date(viewYear, viewMonth, 1);
      const lastDay = new Date(viewYear, viewMonth + 1, 0);
      const daysInMonth = lastDay.getDate();
      const startWeekday = firstDay.getDay(); // 0 = Sun
      const today = new Date();
      const todayIso = isoDate(today.getFullYear(), today.getMonth(), today.getDate());

      const weekdayNames = ['日', '一', '二', '三', '四', '五', '六'];
      let html = '<div class="grid grid-cols-7 bg-neutral-50 border-b border-neutral-200">';
      for (const w of weekdayNames) {
        html += `<div class="px-2 py-2 text-xs font-semibold text-neutral-600 text-center">${w}</div>`;
      }
      html += '</div>';

      html += '<div class="grid grid-cols-7">';
      // 前导空白
      for (let i = 0; i < startWeekday; i++) {
        html += '<div class="border-r border-b border-neutral-100 min-h-[100px] bg-neutral-50/30"></div>';
      }
      for (let d = 1; d <= daysInMonth; d++) {
        const iso = isoDate(viewYear, viewMonth, d);
        const events = buildDayEvents(iso);
        const isToday = iso === todayIso;
        let cellHtml = `<div class="border-r border-b border-neutral-100 min-h-[100px] p-1.5 ${isToday ? 'bg-amber-50/50' : ''}">`;
        cellHtml += `<div class="text-xs ${isToday ? 'font-bold text-amber-700' : 'text-neutral-500'} mb-1">${d}</div>`;
        for (const e of events) {
          const fm = e.item.frontmatter || {};
          const g = GROUP_BY_KEY[e.item.group];
          const baseClass = e.kind === 'shoot'
            ? 'bg-purple-100 text-purple-800 border-purple-200'
            : 'bg-cyan-100 text-cyan-800 border-cyan-200';
          const icon = e.kind === 'shoot' ? '🎬' : '🚀';
          const tip = `${g?.name || e.item.group}${fm.assignee ? ' · @' + fm.assignee : ''}`;
          cellHtml += `<a href="/edit?path=${encodeURIComponent(e.item.path)}" title="${escapeHtml(tip)}"
            class="block text-xs px-1.5 py-0.5 rounded border ${baseClass} mb-0.5 truncate hover:opacity-80 transition">${icon} ${escapeHtml(e.item.title)}</a>`;
        }
        cellHtml += '</div>';
        html += cellHtml;
      }
      // 尾部空白
      const totalCells = startWeekday + daysInMonth;
      const trailing = (7 - (totalCells % 7)) % 7;
      for (let i = 0; i < trailing; i++) {
        html += '<div class="border-r border-b border-neutral-100 min-h-[100px] bg-neutral-50/30"></div>';
      }
      html += '</div>';

      calEl.innerHTML = html;
    }

    document.getElementById('prev-month').addEventListener('click', () => {
      viewMonth--;
      if (viewMonth < 0) { viewMonth = 11; viewYear--; }
      render();
    });
    document.getElementById('next-month').addEventListener('click', () => {
      viewMonth++;
      if (viewMonth > 11) { viewMonth = 0; viewYear++; }
      render();
    });
    document.getElementById('today-btn').addEventListener('click', () => {
      const t = new Date();
      viewYear = t.getFullYear();
      viewMonth = t.getMonth();
      render();
    });

    (async function load() {
      try {
        const r = await fetch('/api/list?frontmatter=1');
        const data = await r.json();
        if (!r.ok) throw new Error(data.error || `HTTP ${r.status}`);
        allItems = data.items || [];
        const t = new Date();
        viewYear = t.getFullYear();
        viewMonth = t.getMonth();
        document.getElementById('loading').classList.add('hidden');
        calEl.classList.remove('hidden');
        render();
      } catch (err) {
        document.getElementById('loading').innerHTML = `<div class="text-red-600">加载失败: ${err.message}</div>`;
      }
    })();
  </script>
</Layout>
