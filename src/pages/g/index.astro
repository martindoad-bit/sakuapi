---
import LayoutG from '../../layouts/LayoutG.astro';
import { STATUSES, PLATFORMS } from '../../lib/workflow';

const statusesJson = JSON.stringify(STATUSES);
const platformsJson = JSON.stringify(PLATFORMS);
const GROUP_KEY = 'gyosei';
---

<LayoutG title="行政書士 · Sakuapi">
  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-8 gap-4 flex-wrap">
      <div>
        <h1 class="text-3xl font-bold tracking-tight mb-2 text-teal-700">行政書士</h1>
        <p class="text-neutral-600">業務関連コンテンツ一覧</p>
      </div>
      <a
        href="/g/new"
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-md font-medium shadow-sm transition text-white bg-teal-600 hover:bg-teal-700"
      >
        <span class="text-lg leading-none">+</span> 新建文章
      </a>
    </div>

    <!-- 状态筛选 -->
    <div class="mb-5 flex flex-wrap items-center gap-2">
      <span class="text-xs text-neutral-500 mr-1">筛选：</span>
      <button data-filter="" class="filter-btn text-xs px-2.5 py-1 rounded-full border border-neutral-300 hover:border-teal-400 transition data-[active=true]:bg-teal-600 data-[active=true]:text-white data-[active=true]:border-teal-600" data-active="true">全部</button>
      {STATUSES.map((s) => (
        <button
          data-filter={s.key}
          class={`filter-btn text-xs px-2.5 py-1 rounded-full border transition ${s.bg} ${s.text} ${s.border} hover:opacity-80`}
        >{s.label}</button>
      ))}
    </div>

    <div id="error-box" class="hidden mb-4 p-4 bg-red-50 border border-red-200 rounded-md text-red-700 text-sm"></div>

    <div id="skeleton" class="space-y-3">
      {[1,2,3].map(() => (
        <div class="bg-white border border-neutral-200 rounded-lg p-5 animate-pulse">
          <div class="h-5 bg-neutral-200 rounded w-2/3 mb-3"></div>
          <div class="h-4 bg-neutral-100 rounded w-1/2"></div>
        </div>
      ))}
    </div>

    <div id="article-list" class="space-y-3 hidden"></div>

    <div id="empty-state" class="hidden text-center py-16 text-neutral-500 border border-dashed border-neutral-300 rounded-lg">
      <p class="mb-3">还没有文章</p>
      <a href="/g/new" class="inline-block px-4 py-2 bg-teal-600 hover:bg-teal-700 text-white rounded-md text-sm font-medium transition">
        + 写第一篇
      </a>
    </div>
  </div>

  <script is:inline define:vars={{ GROUP_KEY, statusesJson, platformsJson }}>
    const STATUSES = JSON.parse(statusesJson);
    const PLATFORMS = JSON.parse(platformsJson);
    const STATUS_BY_KEY = Object.fromEntries(STATUSES.map((s) => [s.key, s]));
    const PLATFORM_BY_KEY = Object.fromEntries(PLATFORMS.map((p) => [p.key, p]));

    const skeleton = document.getElementById('skeleton');
    const listEl = document.getElementById('article-list');
    const emptyEl = document.getElementById('empty-state');
    const errBox = document.getElementById('error-box');

    let articles = [];
    let activeFilter = '';

    function escapeHtml(s) {
      return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    function buildCard(item) {
      const fm = item.frontmatter || {};
      const status = fm.status ? STATUS_BY_KEY[fm.status] : null;
      const platforms = (Array.isArray(fm.platform) ? fm.platform : (fm.platform ? [fm.platform] : []))
        .map((k) => PLATFORM_BY_KEY[k]).filter(Boolean);

      const card = document.createElement('div');
      card.className = 'group bg-white border border-neutral-200 rounded-lg p-5 hover:border-teal-400 hover:shadow-sm transition';
      card.dataset.status = fm.status || '';

      card.innerHTML = `
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0 flex-1">
            <div class="block">
              <h3 class="text-lg font-semibold text-neutral-900 group-hover:text-teal-700 transition mb-2 leading-snug">${escapeHtml(item.title || item.filename.replace(/\.md$/, ''))}</h3>
            </div>
            <div class="flex items-center gap-1.5 flex-wrap mb-2">
              ${status ? `<span class="text-xs px-2 py-0.5 rounded ${status.bg} ${status.text} border ${status.border}">${status.label}</span>` : ''}
              ${fm.assignee ? `<span class="text-xs px-2 py-0.5 rounded bg-neutral-100 text-neutral-700">@${escapeHtml(fm.assignee)}</span>` : ''}
              ${platforms.map((p) => `<span class="text-xs px-1.5 py-0.5 rounded bg-neutral-100 text-neutral-700">${p.emoji} ${p.label}</span>`).join('')}
              ${fm.shoot_date ? `<span class="text-xs px-2 py-0.5 rounded bg-purple-50 text-purple-700 border border-purple-200">🎬 ${fm.shoot_date}</span>` : ''}
              ${fm.publish_date ? `<span class="text-xs px-2 py-0.5 rounded bg-cyan-50 text-cyan-700 border border-cyan-200">🚀 ${fm.publish_date}</span>` : ''}
              ${fm.publish_url ? `<a href="${escapeHtml(fm.publish_url)}" target="_blank" rel="noopener" class="text-xs px-2 py-0.5 rounded bg-emerald-50 text-emerald-700 border border-emerald-200 hover:underline">🔗 已发链接</a>` : ''}
            </div>
            <div class="text-xs text-neutral-500">${escapeHtml(item.batch || '(无批次)')} · ${escapeHtml(item.filename)}</div>
          </div>
          <div class="flex items-center gap-1 shrink-0 opacity-0 group-hover:opacity-100 transition">
            <a href="/g/edit?path=${encodeURIComponent(item.path)}" class="px-2.5 py-1 text-xs text-teal-700 bg-teal-50 hover:bg-teal-100 rounded transition">编辑</a>
            <button data-del class="px-2.5 py-1 text-xs text-red-600 bg-red-50 hover:bg-red-100 rounded transition">删除</button>
          </div>
        </div>
      `;

      const delBtn = card.querySelector('[data-del]');
      delBtn.addEventListener('click', () => onDelete(item, delBtn));
      return card;
    }

    async function onDelete(item, btn) {
      if (!confirm(`确认删除？\n\n${item.title || item.filename}\n\n会立即提交一个删除 commit（git 历史保留）。`)) return;
      btn.disabled = true;
      btn.textContent = '删除中…';
      try {
        const r = await fetch(`/api/article?path=${encodeURIComponent(item.path)}`, { method: 'DELETE' });
        const d = await r.json();
        if (!r.ok) throw new Error(d.error || '删除失败');
        await load();
      } catch (err) {
        alert('删除失败: ' + err.message);
        btn.disabled = false;
        btn.textContent = '删除';
      }
    }

    function render() {
      listEl.innerHTML = '';
      const filtered = activeFilter
        ? articles.filter((a) => (a.frontmatter || {}).status === activeFilter)
        : articles;

      if (filtered.length === 0) {
        listEl.classList.add('hidden');
        emptyEl.classList.remove('hidden');
        if (activeFilter) {
          emptyEl.innerHTML = `<p class="mb-3">没有该状态的文章</p>`;
        }
        return;
      }
      emptyEl.classList.add('hidden');
      listEl.classList.remove('hidden');
      for (const item of filtered) {
        listEl.appendChild(buildCard(item));
      }
    }

    async function load() {
      skeleton.classList.remove('hidden');
      listEl.classList.add('hidden');
      emptyEl.classList.add('hidden');
      try {
        const r = await fetch('/api/list?frontmatter=1');
        const d = await r.json();
        if (!r.ok) throw new Error(d.error || `HTTP ${r.status}`);
        articles = (d.items || []).filter((it) => it.group === GROUP_KEY);
      } catch (err) {
        skeleton.classList.add('hidden');
        errBox.textContent = '加载失败：' + err.message;
        errBox.classList.remove('hidden');
        return;
      }
      skeleton.classList.add('hidden');
      render();
    }

    document.querySelectorAll('.filter-btn').forEach((b) => {
      b.addEventListener('click', () => {
        activeFilter = b.dataset.filter;
        document.querySelectorAll('.filter-btn').forEach((x) => x.dataset.active = (x === b).toString());
        render();
      });
    });

    load();
  </script>
</LayoutG>
