---
import LayoutG from '../../layouts/LayoutG.astro';
import { STATUSES, PLATFORMS } from '../../lib/workflow';

const statusesJson = JSON.stringify(STATUSES);
const platformsJson = JSON.stringify(PLATFORMS);
const GROUP_KEY = 'gyosei';
---

<LayoutG title="文章管理 · Sakuapi">
  <div class="max-w-4xl mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-6 gap-3 flex-wrap">
      <div>
        <h1 class="text-2xl font-bold tracking-tight mb-1">文章管理</h1>
        <p class="text-sm text-neutral-600">所有改动会直接 commit 到 GitHub</p>
      </div>
      <div class="flex items-center gap-2">
        <a href="/g/board" class="px-3 py-2 text-sm border border-neutral-300 rounded-md hover:border-teal-400 hover:text-teal-700 transition">📋 看板</a>
        <a href="/g/calendar" class="px-3 py-2 text-sm border border-neutral-300 rounded-md hover:border-teal-400 hover:text-teal-700 transition">📅 日历</a>
        <a href="/g/new" class="inline-flex items-center gap-1.5 px-4 py-2 bg-teal-600 hover:bg-teal-700 text-white rounded-md font-medium shadow-sm transition">
          <span class="text-lg leading-none">+</span> 新建文章
        </a>
      </div>
    </div>

    <div id="admin-error" class="hidden mb-6 p-4 bg-red-50 border border-red-200 rounded-md text-red-700 text-sm"></div>

    <!-- 状态筛选 -->
    <div class="mb-6 flex flex-wrap items-center gap-2">
      <span class="text-xs text-neutral-500 mr-1">筛选状态：</span>
      <button data-filter-status="" class="filter-btn text-xs px-2.5 py-1 rounded-full border border-neutral-300 hover:border-teal-400 transition data-[active=true]:bg-teal-600 data-[active=true]:text-white data-[active=true]:border-teal-600" data-active="true">全部</button>
      {STATUSES.map((s) => (
        <button data-filter-status={s.key} class={`filter-btn text-xs px-2.5 py-1 rounded-full border transition ${s.bg} ${s.text} ${s.border} hover:opacity-80`}>{s.label}</button>
      ))}
    </div>

    <div id="article-container" class="bg-white border border-neutral-200 rounded-lg p-5">
      <div id="skeleton" class="space-y-3 animate-pulse">
        <div class="h-4 bg-neutral-200 rounded w-2/3"></div>
        <div class="h-4 bg-neutral-100 rounded"></div>
        <div class="h-4 bg-neutral-100 rounded w-3/4"></div>
      </div>
      <ul id="article-list" class="hidden divide-y divide-neutral-100"></ul>
      <div id="empty-state" class="hidden text-sm text-neutral-400 italic">暂无文章</div>
    </div>

    <template id="tpl-row">
      <li class="py-3" data-row>
        <div class="flex items-center justify-between gap-3">
          <div class="min-w-0 flex-1">
            <div class="text-sm font-medium text-neutral-800 truncate" data-title></div>
            <div class="flex items-center gap-2 mt-1 flex-wrap" data-badges></div>
            <div class="text-xs text-neutral-500 mt-1 truncate" data-meta></div>
          </div>
          <div class="flex items-center gap-1 shrink-0 text-xs">
            <a class="px-2 py-1 text-teal-700 hover:bg-teal-50 rounded transition" data-edit>编辑</a>
            <button class="px-2 py-1 text-red-600 hover:bg-red-50 rounded transition" data-del type="button">删除</button>
          </div>
        </div>
      </li>
    </template>
  </div>

  <script is:inline define:vars={{ statusesJson, platformsJson, GROUP_KEY }}>
    const STATUSES = JSON.parse(statusesJson);
    const PLATFORMS = JSON.parse(platformsJson);
    const STATUS_BY_KEY = Object.fromEntries(STATUSES.map((s) => [s.key, s]));
    const PLATFORM_BY_KEY = Object.fromEntries(PLATFORMS.map((p) => [p.key, p]));

    const errBox = document.getElementById('admin-error');
    const listEl = document.getElementById('article-list');
    const skeleton = document.getElementById('skeleton');
    const emptyEl = document.getElementById('empty-state');
    const rowTpl = document.getElementById('tpl-row');

    let activeStatusFilter = '';
    let allItems = [];

    function showError(msg) { errBox.textContent = msg; errBox.classList.remove('hidden'); }

    function buildBadges(item) {
      const wrap = document.createElement('div');
      wrap.className = 'flex items-center gap-1.5 flex-wrap';
      const fm = item.frontmatter || {};
      if (fm.status) {
        const s = STATUS_BY_KEY[fm.status];
        if (s) {
          const b = document.createElement('span');
          b.className = `text-xs px-2 py-0.5 rounded ${s.bg} ${s.text} ${s.border} border`;
          b.textContent = s.label;
          wrap.appendChild(b);
        }
      }
      if (fm.assignee) {
        const b = document.createElement('span');
        b.className = 'text-xs px-2 py-0.5 rounded bg-neutral-100 text-neutral-700';
        b.textContent = '@' + fm.assignee;
        wrap.appendChild(b);
      }
      const platforms = Array.isArray(fm.platform) ? fm.platform : (fm.platform ? [fm.platform] : []);
      for (const pk of platforms) {
        const p = PLATFORM_BY_KEY[pk];
        if (!p) continue;
        const b = document.createElement('span');
        b.className = 'text-xs px-1.5 py-0.5 rounded bg-neutral-100 text-neutral-700';
        b.textContent = p.emoji + ' ' + p.label;
        wrap.appendChild(b);
      }
      return wrap;
    }

    function buildRow(item) {
      const node = rowTpl.content.cloneNode(true);
      const li = node.querySelector('[data-row]');
      const fm = item.frontmatter || {};
      if (activeStatusFilter && fm.status !== activeStatusFilter) li.style.display = 'none';

      node.querySelector('[data-title]').textContent = item.title || item.filename.replace(/\.md$/, '');
      node.querySelector('[data-meta]').textContent = `${item.batch || '(无批次)'} / ${item.filename}`;
      node.querySelector('[data-badges]').appendChild(buildBadges(item));

      const editBtn = node.querySelector('[data-edit]');
      editBtn.href = `/g/edit?path=${encodeURIComponent(item.path)}`;
      const delBtn = node.querySelector('[data-del]');
      delBtn.addEventListener('click', () => onDelete(item, delBtn));
      return node;
    }

    async function onDelete(item, btn) {
      if (!confirm(`确认删除？\n\n${item.title || item.filename}\n\n这会立即在 GitHub 上提交一个删除 commit，无法在网页里撤回（但 git 历史保留）。`)) return;
      btn.disabled = true;
      btn.textContent = '删除中…';
      try {
        const r = await fetch(`/api/article?path=${encodeURIComponent(item.path)}`, { method: 'DELETE' });
        const data = await r.json();
        if (!r.ok) throw new Error(data.error || '删除失败');
        await load();
      } catch (err) {
        alert('删除失败: ' + err.message);
        btn.disabled = false;
        btn.textContent = '删除';
      }
    }

    function render() {
      listEl.innerHTML = '';
      const visible = allItems.filter((i) => !activeStatusFilter || (i.frontmatter || {}).status === activeStatusFilter);
      if (visible.length === 0) {
        listEl.classList.add('hidden');
        emptyEl.classList.remove('hidden');
        return;
      }
      emptyEl.classList.add('hidden');
      listEl.classList.remove('hidden');
      for (const item of visible) listEl.appendChild(buildRow(item));
    }

    async function load() {
      skeleton.classList.remove('hidden');
      listEl.classList.add('hidden');
      emptyEl.classList.add('hidden');
      try {
        const r = await fetch('/api/list?frontmatter=1');
        const data = await r.json();
        if (!r.ok) throw new Error(data.error || `HTTP ${r.status}`);
        allItems = (data.items || []).filter((i) => i.group === GROUP_KEY);
      } catch (err) {
        skeleton.classList.add('hidden');
        showError('加载文章列表失败：' + err.message);
        return;
      }
      skeleton.classList.add('hidden');
      render();
    }

    document.querySelectorAll('.filter-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        activeStatusFilter = btn.dataset.filterStatus;
        document.querySelectorAll('.filter-btn').forEach((b) => b.dataset.active = (b === btn).toString());
        render();
      });
    });

    load();
  </script>
</LayoutG>
